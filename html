<!doctype html>
<html lang="en" class="h-full">
 <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SSC Exam MCQ Generator</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="/_sdk/element_sdk.js"></script>
  <script src="/_sdk/data_sdk.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet">
  <style>
        * { font-family: 'Outfit', sans-serif; }
        .gradient-bg { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); }
        .card-glass { background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.1); }
        .btn-primary { background: linear-gradient(135deg, #e94560 0%, #ff6b6b 100%); }
        .btn-primary:hover { background: linear-gradient(135deg, #ff6b6b 0%, #e94560 100%); }
        .option-btn { transition: all 0.3s ease; }
        .option-btn:hover { transform: translateX(8px); }
        .option-btn.selected { background: rgba(233, 69, 96, 0.3); border-color: #e94560; }
        .option-btn.correct { background: rgba(16, 185, 129, 0.3); border-color: #10b981; }
        .option-btn.incorrect { background: rgba(239, 68, 68, 0.3); border-color: #ef4444; }
        .fade-in { animation: fadeIn 0.5s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        .pulse-glow { animation: pulseGlow 2s infinite; }
        @keyframes pulseGlow { 0%, 100% { box-shadow: 0 0 20px rgba(233, 69, 96, 0.3); } 50% { box-shadow: 0 0 40px rgba(233, 69, 96, 0.6); } }
    </style>
  <style>body { box-sizing: border-box; }</style>
 </head>
 <body class="h-full gradient-bg text-white overflow-auto">
  <div id="app" class="w-full min-h-full p-4 md:p-8"><!-- Header -->
   <header class="text-center mb-8 fade-in">
    <h1 id="exam-title" class="text-3xl md:text-4xl font-bold bg-gradient-to-r from-white via-pink-200 to-white bg-clip-text text-transparent">SSC Exam MCQ Generator</h1>
    <p id="instructions" class="text-gray-400 mt-2">Create, practice, and master your exam preparation</p>
   </header><!-- Navigation Tabs -->
   <nav class="flex justify-center gap-2 mb-8 flex-wrap"><button onclick="showView('create')" id="tab-create" class="px-6 py-2 rounded-full text-sm font-medium transition-all bg-white/10 hover:bg-white/20">Create Questions</button> <button onclick="showView('practice')" id="tab-practice" class="px-6 py-2 rounded-full text-sm font-medium transition-all bg-white/10 hover:bg-white/20">Practice Exam</button> <button onclick="showView('bank')" id="tab-bank" class="px-6 py-2 rounded-full text-sm font-medium transition-all bg-white/10 hover:bg-white/20">Question Bank</button>
   </nav><!-- Create Questions View -->
   <div id="view-create" class="max-w-2xl mx-auto">
    <div class="card-glass rounded-2xl p-6 md:p-8 fade-in">
     <h2 class="text-xl font-semibold mb-6 flex items-center gap-2"><span class="text-2xl">📝</span> Add New Question</h2>
     <div class="space-y-4">
      <div><label class="block text-sm text-gray-400 mb-2">Category</label> <select id="input-category" class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 focus:outline-none focus:border-pink-500 transition-colors"> <option value="General Knowledge">General Knowledge</option> <option value="Math/Reasoning">Math/Reasoning</option> <option value="History/Geography">History/Geography</option> <option value="Current Affairs">Current Affairs</option> <option value="English/Comprehension">English/Comprehension</option> </select>
      </div>
      <div><label class="block text-sm text-gray-400 mb-2">Question</label> <textarea id="input-question" rows="3" placeholder="Enter your question here..." class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 focus:outline-none focus:border-pink-500 transition-colors resize-none"></textarea>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
       <div><label class="block text-sm text-gray-400 mb-2">Option A</label> <input type="text" id="input-option-a" placeholder="First option" class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 focus:outline-none focus:border-pink-500 transition-colors">
       </div>
       <div><label class="block text-sm text-gray-400 mb-2">Option B</label> <input type="text" id="input-option-b" placeholder="Second option" class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 focus:outline-none focus:border-pink-500 transition-colors">
       </div>
       <div><label class="block text-sm text-gray-400 mb-2">Option C</label> <input type="text" id="input-option-c" placeholder="Third option" class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 focus:outline-none focus:border-pink-500 transition-colors">
       </div>
       <div><label class="block text-sm text-gray-400 mb-2">Option D</label> <input type="text" id="input-option-d" placeholder="Fourth option" class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 focus:outline-none focus:border-pink-500 transition-colors">
       </div>
      </div>
      <div><label class="block text-sm text-gray-400 mb-2">Correct Answer</label> <select id="input-correct" class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 focus:outline-none focus:border-pink-500 transition-colors"> <option value="a">Option A</option> <option value="b">Option B</option> <option value="c">Option C</option> <option value="d">Option D</option> </select>
      </div><button onclick="addQuestion()" id="btn-add" class="w-full btn-primary text-white font-semibold py-3 rounded-lg transition-all hover:scale-[1.02] active:scale-[0.98]"> Add Question </button>
      <div id="create-message" class="text-center text-sm hidden"></div>
     </div>
    </div><!-- Sample Questions Section -->
    <div class="card-glass rounded-2xl p-6 mt-6 fade-in">
     <h3 class="text-lg font-semibold mb-4 flex items-center gap-2"><span>✨</span> Quick Add Sample Questions</h3>
     <p class="text-gray-400 text-sm mb-4">Add these pre-made SSC-level questions to your bank:</p>
     <div class="grid gap-2"><button onclick="addSampleQuestions()" class="w-full bg-white/10 hover:bg-white/20 border border-white/20 rounded-lg px-4 py-3 text-left transition-all hover:scale-[1.01]"> <span class="font-medium">📚 Add 10 Sample Questions</span> <span class="text-gray-400 text-sm block">Mixed categories: GK, Math, History, English</span> </button>
     </div>
    </div>
   </div><!-- Practice Exam View -->
   <div id="view-practice" class="max-w-2xl mx-auto hidden"><!-- Exam Setup -->
    <div id="exam-setup" class="card-glass rounded-2xl p-6 md:p-8 fade-in">
     <h2 class="text-xl font-semibold mb-6 flex items-center gap-2"><span class="text-2xl">🎯</span> Start Practice Exam</h2>
     <div class="space-y-4">
      <div><label class="block text-sm text-gray-400 mb-2">Number of Questions</label> <select id="exam-count" class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 focus:outline-none focus:border-pink-500 transition-colors"> <option value="5">5 Questions</option> <option value="10" selected>10 Questions</option> <option value="15">15 Questions</option> <option value="20">20 Questions</option> <option value="all">All Questions</option> </select>
      </div>
      <div><label class="block text-sm text-gray-400 mb-2">Category Filter</label> <select id="exam-category" class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 focus:outline-none focus:border-pink-500 transition-colors"> <option value="all">All Categories</option> <option value="General Knowledge">General Knowledge</option> <option value="Math/Reasoning">Math/Reasoning</option> <option value="History/Geography">History/Geography</option> <option value="Current Affairs">Current Affairs</option> <option value="English/Comprehension">English/Comprehension</option> </select>
      </div>
      <div id="question-count-info" class="text-center text-gray-400 py-2">
       Loading questions...
      </div><button onclick="startExam()" id="btn-start-exam" class="w-full btn-primary text-white font-semibold py-3 rounded-lg transition-all hover:scale-[1.02] active:scale-[0.98] pulse-glow"> Start Exam 🚀 </button>
     </div>
    </div><!-- Active Exam -->
    <div id="exam-active" class="hidden"><!-- Progress Bar -->
     <div class="card-glass rounded-full p-1 mb-6">
      <div class="flex items-center gap-4 px-4 py-2"><span id="exam-progress-text" class="text-sm font-medium">1/10</span>
       <div class="flex-1 h-2 bg-white/10 rounded-full overflow-hidden">
        <div id="exam-progress-bar" class="h-full bg-gradient-to-r from-pink-500 to-red-500 transition-all duration-300" style="width: 10%"></div>
       </div><span id="exam-score-live" class="text-sm font-medium text-green-400">Score: 0</span>
      </div>
     </div><!-- Question Card -->
     <div class="card-glass rounded-2xl p-6 md:p-8 fade-in">
      <div class="flex items-center gap-2 mb-4"><span id="question-category-badge" class="px-3 py-1 bg-white/10 rounded-full text-xs font-medium">Category</span>
      </div>
      <h3 id="question-text" class="text-lg md:text-xl font-medium mb-6 leading-relaxed">Question will appear here...</h3>
      <div id="options-container" class="space-y-3"><!-- Options will be rendered here -->
      </div>
      <div id="answer-feedback" class="mt-6 p-4 rounded-lg hidden"><!-- Feedback will appear here -->
      </div><button onclick="nextQuestion()" id="btn-next" class="w-full mt-6 btn-primary text-white font-semibold py-3 rounded-lg transition-all hover:scale-[1.02] active:scale-[0.98] hidden"> Next Question → </button>
     </div>
    </div><!-- Exam Results -->
    <div id="exam-results" class="hidden">
     <div class="card-glass rounded-2xl p-6 md:p-8 text-center fade-in">
      <div class="text-6xl mb-4">
       🏆
      </div>
      <h2 class="text-2xl font-bold mb-2">Exam Complete!</h2>
      <div id="results-score" class="text-4xl font-bold bg-gradient-to-r from-green-400 to-emerald-500 bg-clip-text text-transparent my-4">
       8/10
      </div>
      <p id="results-percentage" class="text-gray-400 mb-6">80% Accuracy</p>
      <div id="results-breakdown" class="grid grid-cols-2 gap-4 mb-6">
       <div class="bg-green-500/20 rounded-lg p-4">
        <div id="results-correct" class="text-2xl font-bold text-green-400">
         8
        </div>
        <div class="text-sm text-gray-400">
         Correct
        </div>
       </div>
       <div class="bg-red-500/20 rounded-lg p-4">
        <div id="results-incorrect" class="text-2xl font-bold text-red-400">
         2
        </div>
        <div class="text-sm text-gray-400">
         Incorrect
        </div>
       </div>
      </div><button onclick="resetExam()" class="w-full btn-primary text-white font-semibold py-3 rounded-lg transition-all hover:scale-[1.02] active:scale-[0.98]"> Try Again 🔄 </button>
     </div>
    </div>
   </div><!-- Question Bank View -->
   <div id="view-bank" class="max-w-4xl mx-auto hidden">
    <div class="card-glass rounded-2xl p-6 md:p-8 fade-in">
     <div class="flex items-center justify-between mb-6 flex-wrap gap-4">
      <h2 class="text-xl font-semibold flex items-center gap-2"><span class="text-2xl">📚</span> Question Bank</h2>
      <div id="bank-count" class="text-gray-400 text-sm">
       0 questions
      </div>
     </div>
     <div id="bank-empty" class="text-center py-12 hidden">
      <div class="text-5xl mb-4">
       📭
      </div>
      <p class="text-gray-400">No questions yet. Add some questions to get started!</p>
     </div>
     <div id="bank-list" class="space-y-4"><!-- Questions will be rendered here -->
     </div>
    </div>
   </div>
  </div>
  <script>
        // Default configuration
        const defaultConfig = {
            exam_title: "SSC Exam MCQ Generator",
            instructions_text: "Create, practice, and master your exam preparation",
            primary_color: "#e94560",
            secondary_color: "#1a1a2e",
            text_color: "#ffffff",
            accent_color: "#10b981",
            surface_color: "#16213e"
        };

        // State management
        let allQuestions = [];
        let examQuestions = [];
        let currentQuestionIndex = 0;
        let examScore = 0;
        let selectedAnswer = null;
        let answerSubmitted = false;
        let currentRecordCount = 0;

        // Sample questions for SSC exam
        const sampleQuestions = [
            {
                question_text: "What is the capital of India?",
                option_a: "Mumbai",
                option_b: "New Delhi",
                option_c: "Kolkata",
                option_d: "Chennai",
                correct_answer: "b",
                category: "General Knowledge"
            },
            {
                question_text: "If 2x + 5 = 15, what is the value of x?",
                option_a: "3",
                option_b: "4",
                option_c: "5",
                option_d: "6",
                correct_answer: "c",
                category: "Math/Reasoning"
            },
            {
                question_text: "Who was the first President of India?",
                option_a: "Jawaharlal Nehru",
                option_b: "Dr. Rajendra Prasad",
                option_c: "Sardar Patel",
                option_d: "Dr. B.R. Ambedkar",
                correct_answer: "b",
                category: "History/Geography"
            },
            {
                question_text: "Choose the correct synonym of 'Abundant':",
                option_a: "Scarce",
                option_b: "Plentiful",
                option_c: "Limited",
                option_d: "Rare",
                correct_answer: "b",
                category: "English/Comprehension"
            },
            {
                question_text: "The Ganges River originates from which glacier?",
                option_a: "Siachen",
                option_b: "Gangotri",
                option_c: "Pindari",
                option_d: "Zemu",
                correct_answer: "b",
                category: "History/Geography"
            },
            {
                question_text: "What is 25% of 400?",
                option_a: "75",
                option_b: "80",
                option_c: "100",
                option_d: "125",
                correct_answer: "c",
                category: "Math/Reasoning"
            },
            {
                question_text: "Which planet is known as the 'Red Planet'?",
                option_a: "Venus",
                option_b: "Jupiter",
                option_c: "Mars",
                option_d: "Saturn",
                correct_answer: "c",
                category: "General Knowledge"
            },
            {
                question_text: "Find the odd one out: Apple, Mango, Potato, Orange",
                option_a: "Apple",
                option_b: "Mango",
                option_c: "Potato",
                option_d: "Orange",
                correct_answer: "c",
                category: "Math/Reasoning"
            },
            {
                question_text: "The Battle of Plassey was fought in which year?",
                option_a: "1757",
                option_b: "1857",
                option_c: "1947",
                option_d: "1664",
                correct_answer: "a",
                category: "History/Geography"
            },
            {
                question_text: "Choose the correct antonym of 'Generous':",
                option_a: "Kind",
                option_b: "Liberal",
                option_c: "Stingy",
                option_d: "Charitable",
                correct_answer: "c",
                category: "English/Comprehension"
            }
        ];

        // Data handler for SDK
        const dataHandler = {
            onDataChanged(data) {
                allQuestions = data;
                currentRecordCount = data.length;
                updateQuestionCountInfo();
                renderQuestionBank();
            }
        };

        // Initialize SDKs
        async function initializeApp() {
            // Initialize Element SDK
            if (window.elementSdk) {
                window.elementSdk.init({
                    defaultConfig,
                    onConfigChange: async (config) => {
                        document.getElementById('exam-title').textContent = config.exam_title || defaultConfig.exam_title;
                        document.getElementById('instructions').textContent = config.instructions_text || defaultConfig.instructions_text;
                    },
                    mapToCapabilities: (config) => ({
                        recolorables: [
                            {
                                get: () => config.secondary_color || defaultConfig.secondary_color,
                                set: (value) => window.elementSdk.setConfig({ secondary_color: value })
                            },
                            {
                                get: () => config.surface_color || defaultConfig.surface_color,
                                set: (value) => window.elementSdk.setConfig({ surface_color: value })
                            },
                            {
                                get: () => config.text_color || defaultConfig.text_color,
                                set: (value) => window.elementSdk.setConfig({ text_color: value })
                            },
                            {
                                get: () => config.primary_color || defaultConfig.primary_color,
                                set: (value) => window.elementSdk.setConfig({ primary_color: value })
                            },
                            {
                                get: () => config.accent_color || defaultConfig.accent_color,
                                set: (value) => window.elementSdk.setConfig({ accent_color: value })
                            }
                        ],
                        borderables: [],
                        fontEditable: undefined,
                        fontSizeable: undefined
                    }),
                    mapToEditPanelValues: (config) => new Map([
                        ["exam_title", config.exam_title || defaultConfig.exam_title],
                        ["instructions_text", config.instructions_text || defaultConfig.instructions_text]
                    ])
                });
            }

            // Initialize Data SDK
            if (window.dataSdk) {
                const result = await window.dataSdk.init(dataHandler);
                if (!result.isOk) {
                    console.error("Failed to initialize Data SDK");
                }
            }
        }

        // View management
        function showView(viewName) {
            const views = ['create', 'practice', 'bank'];
            views.forEach(v => {
                document.getElementById(`view-${v}`).classList.toggle('hidden', v !== viewName);
                document.getElementById(`tab-${v}`).classList.toggle('bg-pink-500/30', v === viewName);
                document.getElementById(`tab-${v}`).classList.toggle('bg-white/10', v !== viewName);
            });
            
            if (viewName === 'practice') {
                updateQuestionCountInfo();
            }
        }

        // Question management
        async function addQuestion() {
            const question = document.getElementById('input-question').value.trim();
            const optionA = document.getElementById('input-option-a').value.trim();
            const optionB = document.getElementById('input-option-b').value.trim();
            const optionC = document.getElementById('input-option-c').value.trim();
            const optionD = document.getElementById('input-option-d').value.trim();
            const correct = document.getElementById('input-correct').value;
            const category = document.getElementById('input-category').value;

            if (!question || !optionA || !optionB || !optionC || !optionD) {
                showMessage('create-message', 'Please fill in all fields', 'error');
                return;
            }

            if (currentRecordCount >= 999) {
                showMessage('create-message', 'Maximum limit of 999 questions reached. Please delete some questions first.', 'error');
                return;
            }

            const btn = document.getElementById('btn-add');
            btn.disabled = true;
            btn.textContent = 'Adding...';

            const result = await window.dataSdk.create({
                question_text: question,
                option_a: optionA,
                option_b: optionB,
                option_c: optionC,
                option_d: optionD,
                correct_answer: correct,
                category: category,
                created_at: new Date().toISOString()
            });

            btn.disabled = false;
            btn.textContent = 'Add Question';

            if (result.isOk) {
                showMessage('create-message', 'Question added successfully! ✓', 'success');
                clearForm();
            } else {
                showMessage('create-message', 'Failed to add question. Please try again.', 'error');
            }
        }

        async function addSampleQuestions() {
            if (currentRecordCount + sampleQuestions.length > 999) {
                showMessage('create-message', 'Cannot add sample questions. Would exceed 999 question limit.', 'error');
                return;
            }

            for (const q of sampleQuestions) {
                await window.dataSdk.create({
                    ...q,
                    created_at: new Date().toISOString()
                });
            }
            showMessage('create-message', '10 sample questions added! ✓', 'success');
        }

        async function deleteQuestion(question) {
            const result = await window.dataSdk.delete(question);
            if (!result.isOk) {
                console.error('Failed to delete question');
            }
        }

        // UI helpers
        function showMessage(elementId, message, type) {
            const el = document.getElementById(elementId);
            el.textContent = message;
            el.className = `text-center text-sm py-2 ${type === 'success' ? 'text-green-400' : 'text-red-400'}`;
            el.classList.remove('hidden');
            setTimeout(() => el.classList.add('hidden'), 3000);
        }

        function clearForm() {
            document.getElementById('input-question').value = '';
            document.getElementById('input-option-a').value = '';
            document.getElementById('input-option-b').value = '';
            document.getElementById('input-option-c').value = '';
            document.getElementById('input-option-d').value = '';
        }

        function updateQuestionCountInfo() {
            const categoryFilter = document.getElementById('exam-category').value;
            let filtered = allQuestions;
            if (categoryFilter !== 'all') {
                filtered = allQuestions.filter(q => q.category === categoryFilter);
            }
            document.getElementById('question-count-info').textContent = 
                `${filtered.length} questions available in ${categoryFilter === 'all' ? 'all categories' : categoryFilter}`;
            
            const startBtn = document.getElementById('btn-start-exam');
            startBtn.disabled = filtered.length === 0;
            startBtn.classList.toggle('opacity-50', filtered.length === 0);
        }

        function renderQuestionBank() {
            const container = document.getElementById('bank-list');
            const emptyState = document.getElementById('bank-empty');
            const countEl = document.getElementById('bank-count');

            countEl.textContent = `${allQuestions.length} question${allQuestions.length !== 1 ? 's' : ''}`;

            if (allQuestions.length === 0) {
                emptyState.classList.remove('hidden');
                container.innerHTML = '';
                return;
            }

            emptyState.classList.add('hidden');
            
            // Create a map of existing elements
            const existingElements = new Map();
            container.querySelectorAll('[data-question-id]').forEach(el => {
                existingElements.set(el.dataset.questionId, el);
            });

            // Update or create elements
            allQuestions.forEach((q, index) => {
                const id = q.__backendId;
                let el = existingElements.get(id);
                
                if (el) {
                    // Update existing element
                    el.querySelector('.question-text').textContent = `${index + 1}. ${q.question_text}`;
                    el.querySelector('.category-badge').textContent = q.category;
                    existingElements.delete(id);
                } else {
                    // Create new element
                    el = document.createElement('div');
                    el.dataset.questionId = id;
                    el.className = 'bg-white/5 rounded-lg p-4 hover:bg-white/10 transition-colors';
                    el.innerHTML = `
                        <div class="flex items-start justify-between gap-4">
                            <div class="flex-1">
                                <span class="category-badge px-2 py-0.5 bg-pink-500/20 text-pink-300 rounded text-xs">${q.category}</span>
                                <p class="question-text mt-2 font-medium">${index + 1}. ${q.question_text}</p>
                                <div class="mt-2 text-sm text-gray-400 grid grid-cols-2 gap-2">
                                    <span>a) ${q.option_a}</span>
                                    <span>b) ${q.option_b}</span>
                                    <span>c) ${q.option_c}</span>
                                    <span>d) ${q.option_d}</span>
                                </div>
                                <p class="mt-2 text-sm text-green-400">Correct: ${q.correct_answer.toUpperCase()}</p>
                            </div>
                            <button class="delete-btn text-red-400 hover:text-red-300 p-2" title="Delete question">🗑️</button>
                        </div>
                    `;
                    el.querySelector('.delete-btn').onclick = () => deleteQuestion(q);
                    container.appendChild(el);
                }
            });

            // Remove deleted elements
            existingElements.forEach(el => el.remove());
        }

        // Exam functions
        function shuffleArray(array) {
            const shuffled = [...array];
            for (let i = shuffled.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
            }
            return shuffled;
        }

        function startExam() {
            const countValue = document.getElementById('exam-count').value;
            const categoryFilter = document.getElementById('exam-category').value;

            let filtered = allQuestions;
            if (categoryFilter !== 'all') {
                filtered = allQuestions.filter(q => q.category === categoryFilter);
            }

            if (filtered.length === 0) return;

            // Shuffle questions
            let shuffled = shuffleArray(filtered);
            
            // Select number of questions
            const count = countValue === 'all' ? shuffled.length : Math.min(parseInt(countValue), shuffled.length);
            examQuestions = shuffled.slice(0, count);

            // Reset exam state
            currentQuestionIndex = 0;
            examScore = 0;
            selectedAnswer = null;
            answerSubmitted = false;

            // Show exam
            document.getElementById('exam-setup').classList.add('hidden');
            document.getElementById('exam-active').classList.remove('hidden');
            document.getElementById('exam-results').classList.add('hidden');

            renderQuestion();
        }

        function renderQuestion() {
            const question = examQuestions[currentQuestionIndex];
            const total = examQuestions.length;

            // Update progress
            document.getElementById('exam-progress-text').textContent = `${currentQuestionIndex + 1}/${total}`;
            document.getElementById('exam-progress-bar').style.width = `${((currentQuestionIndex + 1) / total) * 100}%`;
            document.getElementById('exam-score-live').textContent = `Score: ${examScore}`;

            // Update question
            document.getElementById('question-category-badge').textContent = question.category;
            document.getElementById('question-text').textContent = `Q${currentQuestionIndex + 1}: ${question.question_text}`;

            // Shuffle options for display
            const options = [
                { key: 'a', text: question.option_a },
                { key: 'b', text: question.option_b },
                { key: 'c', text: question.option_c },
                { key: 'd', text: question.option_d }
            ];

            // Render options
            const container = document.getElementById('options-container');
            container.innerHTML = options.map(opt => `
                <button onclick="selectAnswer('${opt.key}')" 
                        id="option-${opt.key}"
                        class="option-btn w-full text-left p-4 rounded-lg border border-white/20 bg-white/5 hover:bg-white/10 transition-all flex items-center gap-3">
                    <span class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center font-semibold uppercase">${opt.key}</span>
                    <span>${opt.text}</span>
                </button>
            `).join('');

            // Hide feedback and next button
            document.getElementById('answer-feedback').classList.add('hidden');
            document.getElementById('btn-next').classList.add('hidden');

            // Reset state
            selectedAnswer = null;
            answerSubmitted = false;
        }

        function selectAnswer(key) {
            if (answerSubmitted) return;

            // Update selection visuals
            document.querySelectorAll('.option-btn').forEach(btn => {
                btn.classList.remove('selected');
            });
            document.getElementById(`option-${key}`).classList.add('selected');
            selectedAnswer = key;

            // Auto-submit after selection
            submitAnswer();
        }

        function submitAnswer() {
            if (!selectedAnswer || answerSubmitted) return;
            answerSubmitted = true;

            const question = examQuestions[currentQuestionIndex];
            const isCorrect = selectedAnswer === question.correct_answer;

            if (isCorrect) {
                examScore++;
                document.getElementById('exam-score-live').textContent = `Score: ${examScore}`;
            }

            // Show correct/incorrect styling
            document.querySelectorAll('.option-btn').forEach(btn => {
                btn.classList.remove('selected');
                const optKey = btn.id.replace('option-', '');
                if (optKey === question.correct_answer) {
                    btn.classList.add('correct');
                } else if (optKey === selectedAnswer && !isCorrect) {
                    btn.classList.add('incorrect');
                }
            });

            // Show feedback
            const feedback = document.getElementById('answer-feedback');
            feedback.classList.remove('hidden');
            feedback.className = `mt-6 p-4 rounded-lg ${isCorrect ? 'bg-green-500/20 border border-green-500/30' : 'bg-red-500/20 border border-red-500/30'}`;
            feedback.innerHTML = isCorrect 
                ? '<span class="text-green-400 font-medium">✓ Correct!</span>'
                : `<span class="text-red-400 font-medium">✗ Incorrect.</span> <span class="text-gray-300">The correct answer is ${question.correct_answer.toUpperCase()}) ${question['option_' + question.correct_answer]}</span>`;

            // Show next button
            const nextBtn = document.getElementById('btn-next');
            nextBtn.classList.remove('hidden');
            nextBtn.textContent = currentQuestionIndex === examQuestions.length - 1 ? 'View Results →' : 'Next Question →';
        }

        function nextQuestion() {
            if (currentQuestionIndex < examQuestions.length - 1) {
                currentQuestionIndex++;
                renderQuestion();
            } else {
                showResults();
            }
        }

        function showResults() {
            document.getElementById('exam-active').classList.add('hidden');
            document.getElementById('exam-results').classList.remove('hidden');

            const total = examQuestions.length;
            const percentage = Math.round((examScore / total) * 100);

            document.getElementById('results-score').textContent = `${examScore}/${total}`;
            document.getElementById('results-percentage').textContent = `${percentage}% Accuracy`;
            document.getElementById('results-correct').textContent = examScore;
            document.getElementById('results-incorrect').textContent = total - examScore;
        }

        function resetExam() {
            document.getElementById('exam-setup').classList.remove('hidden');
            document.getElementById('exam-active').classList.add('hidden');
            document.getElementById('exam-results').classList.add('hidden');
            updateQuestionCountInfo();
        }

        // Event listeners
        document.getElementById('exam-category').addEventListener('change', updateQuestionCountInfo);
        document.getElementById('exam-count').addEventListener('change', updateQuestionCountInfo);

        // Initialize on load
        initializeApp();
    </script>
